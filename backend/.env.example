# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=1d

# AWS S3 (file uploads)
AWS_REGION=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=

# AWS S3 encrypted MongoDB backups
AWS_BACKUP_BUCKET=
BACKUP_AGE_RECIPIENT=

# Email
EMAIL=
EMAIL_PASSWORD=
EMAIL_FROM=

# SMS API
MESSAGE_API=

# Firebase (push notifications)
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=

# NUM/SISI OAuth2 (placeholder - fill when real credentials available)
NUM_SISI_CLIENT_ID=
NUM_SISI_CLIENT_SECRET=
NUM_SISI_AUTH_URL=https://sisi.num.edu.mn/oauth2/authorize
NUM_SISI_TOKEN_URL=https://sisi.num.edu.mn/oauth2/token
NUM_SISI_USERINFO_URL=https://sisi.num.edu.mn/oauth2/userinfo
NUM_SISI_CALLBACK_URL=http://localhost:4000/auth/sisi/callback
NUM_SISI_SCOPES=openid profile email phone
OAUTH_STATE_SECRET=oauth-state-secret-change-in-production

# Frontend URLs
PATIENT_FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# ICD-11 local Docker API
ICD_API_BASE_URL=http://localhost
ICD_API_VERSION=v2
ICD_RELEASE=2026-01
ICD_LINEARIZATION=mms
ICD_LANGUAGE=en

# Scheduling
LUNCH_START_TIME=12:00
LUNCH_END_TIME=13:00
