# Email
EMAIL=
EMAIL_PASSWORD=

# SMS API
MESSAGE_API=

# Firebase (push notifications)
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=

# NUM/SISI OAuth2 (placeholder - fill when real credentials available)
NUM_SISI_CLIENT_ID=
NUM_SISI_CLIENT_SECRET=
